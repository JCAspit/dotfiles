set relativenumber
set number

syntax on

set nocompatible

set ruler
set showcmd
set showmode

set incsearch
set ignorecase

set cursorline
" set cursorcolumn
hi cursorline cterm=NONE ctermfg=white ctermbg=darkgray

set smartindent
set tabstop=4
" Use spaces instead of tabs
" set expandtab

set history=500

set wildmenu

set backupdir=~/.vim/backups
set directory=~/.vim/swaps
set undodir=~/.vim/undo
